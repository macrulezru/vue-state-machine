{
  "name": "@macrulez/vue-state-machine",
  "version": "0.1.1",
  "description": "Lightweight reactive finite state machines (FSM / statechart) for Vue 3",
  "keywords": [
    "vue",
    "vue3",
    "state-machine",
    "fsm",
    "statechart",
    "composable"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/macrulezru/vue-state-machine"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./devtools": {
      "import": "./dist/devtools/index.mjs",
      "require": "./dist/devtools/index.cjs",
      "types": "./dist/devtools/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.9.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^2.0.0",
    "vue": "^3.4.0"
  }
}
